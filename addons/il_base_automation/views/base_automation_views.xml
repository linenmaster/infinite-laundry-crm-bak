<?xml version="1.0" encoding="utf-8"?>
<odoo>

	<record id="view_base_automation_form_il" model="ir.ui.view">
		<field name="name">Automations</field>
		<field name="model">base.automation</field>
		<field name="inherit_id" ref="base_automation.view_base_automation_form"/>
		<field name="arch" type="xml">
			<xpath expr="//notebook" position="before">
				<group>
					<field name="user_ids" widget="many2many_tags" 
						options="{'no_open': True, 'no_create': True}" 
						placeholder="Select users..."/>
				</group>
			</xpath>
		</field>
	</record>

	<!-- automation Tree View -->
    <record id="view_base_automation_tree_il" model="ir.ui.view">
        <field name="name">base.automation.tree.il</field>
        <field name="model">base.automation</field>
        <field name="inherit_id" ref="base_automation.view_base_automation_tree"/>
        <field name="arch" type="xml">
            <tree position="inside">
                <field name="user_ids" widget="many2many_tags" />
            </tree>
        </field>
    </record>

	<record id="view_base_automation_kanban_il" model="ir.ui.view">
        <field name="name">base.automation.kanban.il</field>
        <field name="model">base.automation</field>
        <field name="inherit_id" ref="base_automation.view_base_automation_kanban"/>
        <field name="arch" type="xml">
        	<xpath expr="//kanban//templates//t/div/div" position="inside">
        		<div class="d-flex flex-column">
        			<span class="fs-2 fw-bold">Allowed Users</span>
        			<field name="user_ids" widget="many2many_tags" domain="[('share', '=', False)]"/>
        		</div>
        	</xpath>
        </field>
    </record>

	<!-- CRM automation Action -->
	<record id="base_automation_act_crm_il" model="ir.actions.act_window">
	    <field name="name">CRM Automation</field>
	    <field name="res_model">base.automation</field>
	    <field name="view_mode">kanban,tree,form</field>
	    <field name="view_id" ref="base_automation.view_base_automation_kanban"/>
	    <field name="context">{'active_test': False}</field>
	    <field name="domain">[('model_id.model','=','crm.lead'),('user_ids','in',[uid])]</field>
	    <field name="help" type="html">
	        <img class="w-100 w-md-75"
	        src="/base_automation/static/img/automation.svg" />
	      <p>
	        Automate <em>everything</em> with Automation Rules
	      </p><p>
	        Send an email when an object changes state, archive records
	        after a month of inactivity or remind yourself to follow-up on
	        tasks when a specific tag is added.
	      </p><p>With Automation Rules, you can automate
	        <em>any</em> workflow.
	      </p>
	    </field>
	</record>

	<menuitem id="menu_sub_crm_automation_il" name="Automion"
	    parent="crm.crm_menu_config" sequence="20"/>
	<menuitem id="menu_base_automation_crm_il" action="base_automation_act_crm_il"
	    parent="menu_sub_crm_automation_il" sequence="1"/>

</odoo>
