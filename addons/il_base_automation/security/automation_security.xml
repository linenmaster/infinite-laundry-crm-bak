<?xml version="1.0" encoding="utf-8"?>

<odoo>

<data noupdate="0">

    <record id="automation_rule_personal" model="ir.rule">
        <field name="name">Personal Automation Rule</field>
        <field ref="base_automation.model_base_automation" name="model_id"/>
        <field name="domain_force">[('user_ids','in',[user.id])]</field>
        <field name="groups" eval="[(4, ref('sales_team.group_sale_manager'))]"/>
        <field name="perm_unlink" eval="False"/>
    </record>

    <record id="automation_rule_all" model="ir.rule">
        <field name="name">All Automation Rule</field>
        <field ref="base_automation.model_base_automation" name="model_id"/>
        <field name="domain_force">[(1,'=',1)]</field>
        <field name="groups" eval="[(4, ref('base.group_erp_manager'))]"/>
    </record>

</data>

</odoo>
