<?xml version='1.0' encoding='utf-8'?>
<odoo>
    <data>

        <record id="res_config_settings_view_form_il" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.il</field>
            <field name="model">res.config.settings</field>
            <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
            <field name="arch" type="xml">
            	<xpath expr="//setting[@id='email_servers_setting']" position="after">
                    <setting id="setting_mail_reply_to" string="Default Reply-To" 
                    		help="Set default reply-to.">
                        <field name="mail_reply_to"/>
                    </setting>
                </xpath>
            </field>
        </record>

    </data>
</odoo>
