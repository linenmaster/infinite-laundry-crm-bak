<?xml version="1.0" encoding="utf-8"?>

<odoo>
    <record model="ir.ui.view" id="crm_stage_form">
        <field name="name">crm.stage.form (in crm_stage_multi_company)</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_form"/>
        <field name="arch" type="xml">
            <field name="team_id" position="before">
                <field name="company_ids" options="{'no_open': True, 'no_create': True}" groups="base.group_multi_company" widget="many2many_tags"/>
            </field>
        </field>
    </record>
	<record model="ir.ui.view" id="crm_stage_tree_infinite">
        <field name="name">crm.stage.form (in crm_stage_multi_company).infinite</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_stage_tree"/>
        <field name="arch" type="xml">
            <field name="is_won" position="before">
            	<field name="company_ids" options="{'no_open': True, 'no_create': True}" groups="base.group_multi_company" widget="many2many_tags"/>
            </field>
            <field name="team_id" position="replace">
            	<field name="team_id" column_invisible="True"/>
            </field>
        </field>
    </record>
    <record model="ir.ui.view" id="crm_lead_stage_search_infinite">
        <field name="name">crm.stage.search.infinite</field>
        <field name="model">crm.stage</field>
        <field name="inherit_id" ref="crm.crm_lead_stage_search"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="company_ids"/>
            </field>
            <xpath expr="//search" position="inside">
            	<separator/>
	            <group expand="0" string="Group By">
	                <filter string="Company" name="gb_company_ids" context="{'group_by':'company_ids'}"/>
	            </group>
            </xpath> 
        </field>
    </record>
    
    <record model="ir.ui.view" id="crm_lead_view_form_infinite">
        <field name="name">crm.lead.form.infinite</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
            	<button name="action_send_email_to_customer" string="Email To Customer" 
            		class="oe_highlight" type="object" 
                    invisible="not partner_id"  />
            </xpath> 
        </field>
    </record>

	<data noupdate="1">
        <record id="email_template_pipeline_customer" model="mail.template">
            <field name="name">Pipeline: Email to Customer</field>
            <field name="model_id" ref="crm.model_crm_lead"/>
            <field name="subject">New Pipeline {{ object.company_id.name }}</field>
            <field name="email_from">{{ (object.user_id.email_formatted or user.company_id.email_formatted) }}</field>
            <field name="email_to">{{ object.partner_id.email_formatted }}</field>
            <field name="body_html" type="html">
            	<table border="0" cellpadding="0" cellspacing="0" style="padding-top: 16px; background-color: #F1F1F1; font-family:Verdana, Arial,sans-serif; color: #454748; width: 100%; border-collapse:separate;"><tr><td align="center">
				<table border="0" cellpadding="0" cellspacing="0" width="590" style="padding: 24px; background-color: white; color: #454748; border-collapse:separate;">
				<tbody>
					<!-- CONTENT -->
				    <tr>
				        <td style="min-width: 590px;">
				            <table border="0" cellpadding="0" cellspacing="0" width="590" style="min-width: 590px; background-color: white; padding: 0px 8px 0px 8px; border-collapse:separate;">
				                <tr>
				                    <td valign="top" style="font-size: 13px;">
				                        <div>
				                            Hi <t t-out="object.partner_id and object.partner_id.name or ''">Deco Addict</t>,<br/><br/>
				                            Welcome to <t t-out="object.company_id.name or ''">My Company (San Francisco)</t>.
				                            It's great to meet you! Now that you're on board, you'll discover what <t t-out="object.company_id.name or ''">My Company (San Francisco)</t> has to offer.<br/>
				                            Feel free to reach out at any time!<br/><br/>
				                            Best,<br/>
			                                <t t-out="object.company_id.name or ''">My Company (San Francisco)</t>
				                        </div>
				                    </td>
				                </tr>
				            </table>
				        </td>
				    </tr>
				</tbody>
				</table>
				</td>
				</tr>
				</table>
            </field>
            <field name="auto_delete" eval="True"/>
        </record>
    </data>

</odoo>
